<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <%- include('partials/head', { title: 'Search' }) %>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        .markdown-body p { margin-bottom: 0.5rem; }
        .markdown-body ul { list-style-type: disc; margin-left: 1.5rem; margin-bottom: 0.5rem; }
        .markdown-body strong { color: #e5e7eb; }
        .typing-dot { animation: typing 1.4s infinite ease-in-out both; }
        .typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }
        @keyframes typing {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }
        .markdown-body table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 1.5rem 0; font-size: 0.9em; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
        .markdown-body th { background-color: rgba(255,255,255,0.05); text-align: left; padding: 14px 16px; font-weight: 700; color: #60a5fa; border-bottom: 1px solid rgba(37, 99, 235, 0.3); text-transform: uppercase; font-size: 0.8em; letter-spacing: 0.05em; }
        .markdown-body td { padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.05); color: #d1d5db; }
        .markdown-body tr:last-child td { border-bottom: none; }
        .markdown-body tr:nth-child(even) { background-color: rgba(255,255,255,0.02); }
        .markdown-body tr:hover td { background-color: rgba(37, 99, 235, 0.05); transition: background-color 0.2s ease; }
    </style>
</head>
<body class="bg-dark-900 text-gray-100 h-screen overflow-hidden flex flex-col md:flex-row font-outfit">

    <%- include('partials/sidebar', { activePage: 'search' }) %>

    <main class="flex-1 flex flex-col relative bg-dark-900 overflow-hidden w-full h-full">
        
        <div id="chat-view" class="flex-1 flex flex-col relative w-full h-full overflow-hidden">
            
            
            <div id="center-search-container" class="absolute inset-0 flex flex-col items-center justify-center p-6 z-20">
                <h2 class="text-5xl md:text-6xl font-black text-gray-100 tracking-tight mb-8 text-center">Find Your <span class="text-blue-500">Perfect Ride.</span></h2>
                
                <form id="chat-form" class="w-full max-w-3xl flex items-center gap-3 relative transition-all duration-300">
                    <button type="button" id="btn-tips" class="w-14 h-14 rounded-full bg-dark-700 border border-white/10 text-gray-400 hover:text-blue-500 hover:border-blue-500/30 shadow-md flex items-center justify-center transition-all flex-shrink-0 focus:outline-none focus:ring-2 focus:ring-blue-500 group">
                        <i class="fa-solid fa-lightbulb text-xl group-hover:animate-pulse"></i>
                    </button>
                    <div class="flex-1 relative bg-dark-700/80 backdrop-blur-md rounded-full shadow-2xl border border-white/10 focus-within:border-blue-500/50 focus-within:ring-4 focus-within:ring-blue-500/20 transition-all flex items-center overflow-hidden h-16">
                        <input type="text" id="chat-input" class="w-full h-full bg-transparent pl-8 pr-16 outline-none text-gray-100 text-lg placeholder-gray-500" placeholder="Ask me to search, recommend, or compare..." autocomplete="off">
                        <button type="submit" id="btn-send" class="absolute right-2 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 text-white hover:shadow-lg hover:shadow-blue-500/30 flex items-center justify-center transition-all focus:outline-none transform hover:scale-105">
                            <i class="fa-solid fa-paper-plane ml-[-2px]"></i>
                        </button>
                    </div>
                </form>

            </div>

            <div id="chat-history" class="flex-1 overflow-y-auto p-6 md:p-10 space-y-8 custom-scrollbar hidden z-10" style="padding-bottom: 200px;">
            </div>

            <div id="bottom-search-container" class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-dark-900 via-dark-900 to-transparent z-30 hidden">
            </div>

        </div>

    </main>

    <div id="tips-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex items-center justify-center opacity-0 transition-opacity duration-300">
        <div class="bg-dark-700 rounded-3xl shadow-2xl p-8 max-w-xl w-full mx-4 border border-white/10 transform scale-95 transition-transform duration-300">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-black text-gray-100">How to search</h2>
                <button id="close-tips" class="text-gray-500 hover:text-red-400 transition-colors"><i class="fa-solid fa-xmark text-2xl"></i></button>
            </div>
            <div class="space-y-5">
                <div>
                    <h4 class="font-bold text-blue-400 mb-2 uppercase text-xs tracking-wider"><i class="fa-solid fa-magnifying-glass mr-1"></i> Search</h4>
                    <p class="text-gray-400 text-sm italic bg-dark-600 p-3 rounded-xl border border-white/5">"Search for toyota corolla around 50k km, less than 2 million, good condition, from 2020 to 2024"</p>
                </div>
                <div class="flex gap-4">
                    <div class="flex-1">
                        <h4 class="font-bold text-green-400 mb-2 uppercase text-xs tracking-wider"><i class="fa-solid fa-wand-magic-sparkles mr-1"></i> Recommend</h4>
                        <p class="text-gray-400 text-sm italic bg-dark-600 p-3 rounded-xl border border-white/5">"Recommend a fuel-efficient SUV for a family of 5"</p>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-purple-400 mb-2 uppercase text-xs tracking-wider"><i class="fa-solid fa-code-compare mr-1"></i> Compare</h4>
                        <p class="text-gray-400 text-sm italic bg-dark-600 p-3 rounded-xl border border-white/5">"Compare new BMW 320i with used Mercedes C200 2024"</p>
                    </div>
                </div>

                <div class="pt-5 border-t border-white/5">
                    <p class="text-sm font-bold text-gray-200 mb-3">💡 Advanced Search Terms you can use:</p>
                    <ul class="text-[13px] text-gray-400 space-y-2.5">
                        <li><strong class="text-gray-300">Conditions:</strong> new, used, excellent, very good, good, fair, poor</li>
                        <li><strong class="text-gray-300">Mechanics:</strong> manual, automatic, RWD, AWD, FWD, gas, electric, hybrid, V8, I6, V12</li>
                        <li><strong class="text-gray-300">Attributes:</strong> brand, model, trim, year, price, mileage, color, body shape, engine capacity, horsepower</li>
                        <li><strong class="text-gray-300">Modifiers:</strong> around, under, between, older, newer, more than, less than</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script type="module">
        import { initializeApp } from "firebase/app";
        import { getAuth, onAuthStateChanged } from "firebase/auth";
        import { firebaseConfig } from "/firebase-config.js";

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);

        onAuthStateChanged(auth, (user) => {
            window.firebaseUser = user;
        });
    </script>

    <script>
        const chatView = document.getElementById('chat-view');
        window.openCarPage = function(carId) {
            if(!carId || carId === 'undefined') return;
            sessionStorage.setItem('3arabeetak_last_list_route', 'chatbot');
            window.location.href = '/car/' + carId;
        };

        const chatForm = document.getElementById('chat-form');
        const chatInput = document.getElementById('chat-input');
        const chatHistoryEl = document.getElementById('chat-history');
        const tipsBtn = document.getElementById('btn-tips');
        const tipsModal = document.getElementById('tips-modal');
        const closeTips = document.getElementById('close-tips');
        
        function scrollToBottom() {
            requestAnimationFrame(() => {
                setTimeout(() => {
                    if (chatHistoryEl) chatHistoryEl.scrollTop = chatHistoryEl.scrollHeight;
                }, 120);
            });
        }

        function activateChatLayout() {
            const centerContainer = document.getElementById('center-search-container');
            const bottomContainer = document.getElementById('bottom-search-container');
            if (!centerContainer.classList.contains('hidden')) {
                centerContainer.classList.add('hidden');
                bottomContainer.classList.remove('hidden');
                chatHistoryEl.classList.remove('hidden');
                chatForm.classList.remove('max-w-3xl');
                chatForm.classList.add('max-w-4xl', 'mx-auto');
                bottomContainer.appendChild(chatForm);
            }
        }

        tipsBtn.onclick = () => {
            tipsModal.classList.remove('hidden');
            setTimeout(() => {
                tipsModal.classList.remove('opacity-0');
                tipsModal.firstElementChild.classList.remove('scale-95');
            }, 10);
        };
        closeTips.onclick = () => {
            tipsModal.classList.add('opacity-0');
            tipsModal.firstElementChild.classList.add('scale-95');
            setTimeout(() => tipsModal.classList.add('hidden'), 300);
        };

        let isViewOnly = <%= typeof viewOnly !== 'undefined' && viewOnly ? 'true' : 'false' %>;

        let sessionChat = [];
        let currentChatId = null;

        if (isViewOnly) {
            sessionChat = JSON.parse(sessionStorage.getItem('view_only_chat')) || [];
        } else {
            sessionChat = JSON.parse(sessionStorage.getItem('autovault_chat')) || [];
            currentChatId = sessionStorage.getItem('autovault_chat_id') || null;
        }

        window.chatCarGrids = {};

        async function autoSaveChat() {
            if (isViewOnly || !window.firebaseUser || sessionChat.length === 0) return;
            try {
                const token = await window.firebaseUser.getIdToken();
                const response = await fetch('/api/chats/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idToken: token, chatLog: sessionChat, chatId: currentChatId })
                });
                if (response.ok) {
                    const data = await response.json();
                    if (data.chatId && data.chatId !== currentChatId) {
                        currentChatId = data.chatId;
                        sessionStorage.setItem('autovault_chat_id', currentChatId);
                    }
                }
            } catch (e) {
                console.error('Error auto-saving chat:', e);
            }
        }
        function getCoverImage(imageStr) {
            const DEFAULT_IMG = 'https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&q=80&w=800';
            if(!imageStr) return DEFAULT_IMG;
            const images = parseImagesLogic(imageStr);
            return images.length > 0 ? images[0] : DEFAULT_IMG;
        }

        window.createCarCardHtml = function(car) {
            const safeId = car['Car ID'] || car.car_id || car.carId || car.id || '';
            const brand = (car.brand || '').replace(/'/g, "\\'");
            const model = (car.model || '').replace(/'/g, "\\'");
            const trim = car.trim || '';
            const year = car.year || '';
            
            const imageStr = car['image paths'] || car.image_paths || car.ImagePaths || car.images || '';
            const displayImage = getCoverImage(imageStr);

            const price = car.price || car.avg_price;
            const formattedPrice = price ? Number(price).toLocaleString() + ' EGP' : 'N/A';
            
            const carConditionRaw = car['car condition'] || car.car_condition || '';
            const isNew = carConditionRaw.toLowerCase() === 'new' || carConditionRaw.toLowerCase() === 'brand new';
            const displayCondition = isNew ? 'New' : (car.condition && String(car.condition).trim() !== '-' && String(car.condition).trim() !== '' ? car.condition : (carConditionRaw || 'Used'));

            let statsHtml = '';
            if (!isNew) {
                const mileageVal = car.mileage || car.avg_mileage;
                const formattedMileage = mileageVal ? Number(mileageVal).toLocaleString() + ' km' : '0 km';
                statsHtml = `
                <div class="flex flex-col">
                    <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Mileage</span>
                    <span class="text-sm font-semibold text-gray-300">${formattedMileage}</span>
                </div>
                <div class="flex flex-col">
                    <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Condition</span>
                    <span class="text-sm font-semibold text-gray-300 truncate capitalize" title="${displayCondition}">${displayCondition}</span>
                </div>`;
            } else {
                statsHtml = `
                <div class="flex flex-col">
                    <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Condition</span>
                    <span class="text-sm font-semibold text-gray-300 truncate capitalize" title="${displayCondition}">${displayCondition}</span>
                </div>`;
            }

            const currentCompareList = getCompareList();
            const isCompared = currentCompareList.some(c => String(c.id) === String(safeId));
            const compareBtnClass = isCompared ? 'bg-emerald-500 text-white border-emerald-500' : 'bg-blue-600 hover:bg-blue-500 text-white border-transparent';
            const compareBtnText = isCompared ? '<i class="fa-solid fa-check mr-1"></i> Added' : '<i class="fa-solid fa-plus mr-1"></i> Compare';

            const compareClick = `event.stopPropagation(); typeof toggleCompare === 'function' && toggleCompare(event, '${safeId}', '${brand} ${model}', '${displayImage}')`;

            return `
            <div class="bg-dark-700 border border-white/5 rounded-2xl overflow-hidden hover:border-blue-500/30 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-300 flex flex-col group cursor-pointer" onclick="openCarPage('${safeId}')">
                <div class="relative h-48 bg-dark-800 overflow-hidden">
                    <img src="${displayImage}" alt="${brand} ${model}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&q=80&w=800'">
                    <div class="absolute top-3 right-3 bg-black/60 backdrop-blur-sm px-2.5 py-1 rounded shadow-sm z-10">
                        <span class="text-xs font-black text-white">${year}</span>
                    </div>
                    <button class="btn-compare-icon absolute top-3 left-3 px-2.5 py-1 rounded shadow-sm text-xs font-bold border transition-colors z-20 ${compareBtnClass}" data-car-id="${safeId}" onclick="${compareClick}">
                        ${compareBtnText}
                    </button>
                </div>
                <div class="p-5 flex-grow flex flex-col">
                    <h3 class="text-lg font-black text-gray-100 leading-tight group-hover:text-blue-400 transition-colors">${brand} <span class="font-normal text-gray-400">${model}</span></h3>
                    ${trim ? `<p class="text-sm text-gray-500 font-medium mt-0.5 line-clamp-1" title="${trim}">${trim}</p>` : ''}
                    <div class="text-blue-400 font-extrabold text-lg mt-1 mb-4">${formattedPrice}</div>
                    <div class="grid grid-cols-2 gap-y-3 gap-x-2 mt-auto pt-4 border-t border-white/5">
                        ${statsHtml}
                        <div class="flex flex-col">
                            <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Trans</span>
                            <span class="text-sm font-semibold text-gray-300 truncate capitalize">${car.transmission || car.Transmission || 'N/A'}</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Fuel</span>
                            <span class="text-sm font-semibold text-gray-300 truncate capitalize">${car['fuel type'] || car.fuel_type || 'N/A'}</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Body</span>
                            <span class="text-sm font-semibold text-gray-300 truncate capitalize">${car['body type'] || car.body_type || 'N/A'}</span>
                        </div>
                    </div>
                </div>
            </div>`;
        }

        window.loadMoreChatCars = function(gridId) {
            const gridData = window.chatCarGrids[gridId];
            if (!gridData) return;
            const container = document.getElementById(gridId);
            const btn = document.getElementById(`btn-load-${gridId}`);
            const limit = 10;
            const start = gridData.displayed;
            const end = Math.min(start + limit, gridData.cars.length);
            for (let i = start; i < end; i++) {
                container.insertAdjacentHTML('beforeend', window.createCarCardHtml(gridData.cars[i]));
            }
            gridData.displayed = end;
            if (gridData.displayed >= gridData.cars.length) btn.classList.add('hidden');
            else btn.classList.remove('hidden');
            scrollToBottom();
        };

        function appendMessage(role, text, cars = []) {
            const wrapper = document.createElement('div');
            wrapper.className = `flex gap-4 ${role === 'user' ? 'flex-row-reverse' : ''} animate-fade-in-up w-full`;
            const avatar = role === 'user' 
                ? `<div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center flex-shrink-0 shadow-md"><i class="fa-solid fa-user"></i></div>`
                : `<div class="w-10 h-10 rounded-full bg-dark-600 text-blue-400 flex items-center justify-center flex-shrink-0 shadow-md border border-white/10"><i class="fa-solid fa-car"></i></div>`;
            const bubbleClass = role === 'user' 
                ? 'bg-blue-600 text-white rounded-tr-none max-w-2xl ml-auto' 
                : 'bg-dark-700 border border-white/5 text-gray-200 rounded-tl-none max-w-4xl w-fit overflow-hidden';
            
            let htmlContent = `<div class="flex-1 flex flex-col w-full overflow-hidden">`;
            htmlContent += `<div class="${bubbleClass} p-5 rounded-2xl shadow-sm markdown-body text-[15px] leading-relaxed">`;
            htmlContent += role === 'user' ? text : marked.parse(text);
            htmlContent += `</div>`;
            
            if (cars && cars.length > 0) {
                const gridId = 'grid-' + Math.random().toString(36).substr(2, 9);
                window.chatCarGrids[gridId] = { cars: cars, displayed: 0 };
                htmlContent += `<div id="${gridId}" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mt-6 w-full"></div>`;
                htmlContent += `
                <div class="text-center mt-10 mb-8 w-full">
                    <button id="btn-load-${gridId}" class="px-8 py-3.5 bg-dark-700 border border-white/10 font-bold rounded-xl text-gray-300 hover:bg-dark-600 hover:text-blue-400 shadow-sm transition-all focus:ring-4 focus:ring-blue-500/10 uppercase tracking-widest text-sm hidden" onclick="loadMoreChatCars('${gridId}')">
                        Load More Cars
                    </button>
                </div>`;
            }
            htmlContent += `</div>`; 
            wrapper.innerHTML = avatar + htmlContent;
            chatHistoryEl.appendChild(wrapper);
            
            if (cars && cars.length > 0) {
                const gridId = wrapper.querySelector('[id^="grid-"]').id;
                window.loadMoreChatCars(gridId);
            } else {
                scrollToBottom();
            }
        }

        function showTyping() {
            removeTyping();
            const wrapper = document.createElement('div');
            wrapper.id = 'typing-indicator';
            wrapper.className = `flex gap-4 animate-fade-in-up w-full`;
            wrapper.style.marginBottom = '120px';
            wrapper.innerHTML = `
                <div class="w-10 h-10 rounded-full bg-dark-600 text-blue-400 flex items-center justify-center flex-shrink-0 shadow-md border border-white/10">
                    <i class="fa-solid fa-car"></i>
                </div>
                <div class="bg-dark-700 border border-white/5 px-5 py-4 rounded-2xl rounded-tl-none shadow-sm flex items-center gap-1.5 w-fit">
                    <div class="w-2 h-2 bg-blue-500 rounded-full typing-dot"></div>
                    <div class="w-2 h-2 bg-blue-500 rounded-full typing-dot"></div>
                    <div class="w-2 h-2 bg-blue-500 rounded-full typing-dot"></div>
                </div>
            `;
            chatHistoryEl.appendChild(wrapper);
            scrollToBottom();
        }

        function removeTyping() {
            const indicator = document.getElementById('typing-indicator');
            if(indicator) indicator.remove();
        }

        if (sessionChat.length > 0) {
            activateChatLayout();
            sessionChat.forEach(msg => appendMessage(msg.role, msg.text, msg.cars));
        }

        if (isViewOnly) {
            const botCont = document.getElementById('bottom-search-container');
            if (botCont) botCont.style.display = 'none';
        }

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (isViewOnly) return;
            const text = chatInput.value.trim();
            if(!text) return;
            
            activateChatLayout(); 
            appendMessage('user', text);
            sessionChat.push({ role: 'user', text: text, cars: [] });
            sessionStorage.setItem('autovault_chat', JSON.stringify(sessionChat));
            chatInput.value = '';
            showTyping();
            
            // Auto-save immediately after user query
            await autoSaveChat();
            
            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text })
                });
                const data = await response.json();
                removeTyping();
                appendMessage('bot', data.text, data.cars);
                sessionChat.push({ role: 'bot', text: data.text, cars: data.cars });
                sessionStorage.setItem('autovault_chat', JSON.stringify(sessionChat));
                
                // Auto-save after response
                await autoSaveChat();
            } catch (err) {
                removeTyping();
                const errorMsg = "Sorry, I couldn't reach the server. Please check the connection.";
                appendMessage('bot', errorMsg);
                sessionChat.push({ role: 'bot', text: errorMsg, cars: [] });
                sessionStorage.setItem('autovault_chat', JSON.stringify(sessionChat));
                
                // Auto-save after error
                await autoSaveChat();
            }
        });

        // Auto-save on page unload (fire-and-forget with sendBeacon)
        window.addEventListener('beforeunload', () => {
            if (!isViewOnly && window.firebaseUser && sessionChat.length > 0) {
                try {
                    const cachedToken = window._cachedFirebaseToken;
                    if (cachedToken) {
                        const blob = new Blob(
                            [JSON.stringify({ idToken: cachedToken, chatLog: sessionChat, chatId: currentChatId })],
                            { type: 'application/json' }
                        );
                        navigator.sendBeacon('/api/chats/save', blob);
                        sessionStorage.removeItem('autovault_chat');
                        sessionStorage.removeItem('autovault_chat_id');
                    }
                } catch(e) { /* best effort */ }
            }
        });

        // Keep a cached token for sendBeacon
        setInterval(async () => {
            if (window.firebaseUser) {
                try {
                    window._cachedFirebaseToken = await window.firebaseUser.getIdToken();
                } catch(e) {}
            }
        }, 5 * 60 * 1000); // refresh every 5 minutes
        // Also cache immediately when user state changes
        if (window.firebaseUser) {
            window.firebaseUser.getIdToken().then(t => { window._cachedFirebaseToken = t; }).catch(() => {});
        }
    </script>
</body>
</html>