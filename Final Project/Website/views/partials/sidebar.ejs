<!-- Mobile Header Overlay Toggle -->
<div class="md:hidden bg-dark-800 border-b border-white/5 p-4 flex justify-between items-center sticky top-0 z-30 shadow-lg">
    <a href="/" class="text-2xl font-black tracking-tighter text-blue-500">3arabeetak.</a>
    <button id="mobile-menu-btn" class="text-gray-400 hover:text-blue-500 focus:outline-none">
        <i class="fa-solid fa-bars text-2xl"></i>
    </button>
</div>

<!-- Sidebar -->
<aside id="main-sidebar" class="fixed inset-y-0 left-0 w-64 bg-dark-800 border-r border-white/5 shadow-2xl flex flex-col z-40 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out md:static md:flex-shrink-0">
    <div class="p-6 border-b border-white/5 flex justify-between items-center">
        <a href="/" class="text-3xl font-black tracking-tighter text-blue-500 hover:text-blue-400 transition-colors">3arabeetak.</a>
        <button id="close-menu-btn" class="md:hidden text-gray-500 hover:text-red-400 transition-colors">
            <i class="fa-solid fa-xmark text-2xl"></i>
        </button>
    </div>
    <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto custom-scrollbar">
        <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'search' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-magnifying-glass w-5 text-center"></i> Search
        </a>
        <a href="/new" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'new' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-car w-5 text-center"></i> New Cars
        </a>
        <a href="/used" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'used' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-car-side w-5 text-center"></i> Used Cars
        </a>
        <a href="/valuation" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'valuation' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-calculator w-5 text-center"></i> Car Valuation
        </a>
        <a href="/import-calculator" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'import' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-ship w-5 text-center"></i> Import Calculator
        </a>
        <a href="/trends" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'trends' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-chart-line w-5 text-center"></i> Trends
        </a>
        <a href="/compare" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'compare' ? 'bg-blue-500/10 text-blue-400 font-bold shadow-sm shadow-blue-500/5' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-code-compare w-5 text-center"></i> Compare
        </a>
    </nav>
    <div class="p-4 border-t border-white/5 mt-auto">
        <a href="/profile" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= locals.activePage === 'profile' ? 'bg-blue-500/10 text-blue-400 font-bold' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200 font-medium' %>">
            <i class="fa-solid fa-user w-5 text-center"></i> Profile
        </a>
    </div>
</aside>

<!-- Overlay background for mobile -->
<div id="mobile-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-30 hidden md:hidden transition-opacity"></div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const closeMenuBtn = document.getElementById('close-menu-btn');
        const sidebar = document.getElementById('main-sidebar');
        const overlay = document.getElementById('mobile-overlay');

        function toggleMenu() {
            const isOpen = !sidebar.classList.contains('-translate-x-full');
            if (isOpen) {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            } else {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
            }
        }

        if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', toggleMenu);
        if (closeMenuBtn) closeMenuBtn.addEventListener('click', toggleMenu);
        if (overlay) overlay.addEventListener('click', toggleMenu);
    });
</script>
