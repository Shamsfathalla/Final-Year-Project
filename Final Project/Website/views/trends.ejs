<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <%- include('partials/head', { title: 'Market Trends' }) %>
</head>
<body class="bg-dark-900 text-gray-100 h-screen overflow-hidden flex flex-col md:flex-row font-outfit">
    <%- include('partials/sidebar', { activePage: 'trends' }) %>

    <main class="flex-1 overflow-y-auto w-full h-full relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="mb-8">
                <h1 class="text-4xl font-black text-gray-100 tracking-tight">Market <span class="text-blue-400">Trends</span></h1>
                <p class="text-gray-500 mt-2">Track historical price movements across the Egyptian car market.</p>
            </div>

            <div class="flex flex-col md:flex-row gap-4 mb-8">
                <select id="brand-filter" class="flex-1 px-4 py-3.5 bg-dark-700 border border-white/10 rounded-xl text-gray-200 focus:outline-none focus:border-blue-500/40 transition-shadow hover:border-white/20">
                    <option value="">All Brands</option>
                </select>
            </div>

            <div class="flex items-center justify-between mb-6">
                <p id="results-count" class="text-sm text-gray-500 font-medium">Loading...</p>
            </div>

            <div id="trends-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
            </div>

            <div id="loading" class="hidden flex justify-center py-16">
                <i class="fa-solid fa-spinner fa-spin text-4xl text-blue-500"></i>
            </div>

            <div class="text-center mt-10 mb-8">
                <button id="load-more-btn" class="hidden px-8 py-3.5 bg-dark-700 border border-white/10 font-bold rounded-xl text-gray-300 hover:bg-dark-600 hover:text-blue-400 shadow-sm transition-all uppercase tracking-widest text-sm">
                    Load More
                </button>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script>
        let currentOffset = 0;
        const LIMIT = 50;
        let searchTimeout;

        function formatEGP(val) {
            if (!val) return 'N/A';
            return Math.round(val).toLocaleString() + ' EGP';
        }

        function formatMonthYear(dateStr) {
            if (!dateStr || dateStr === '—') return '—';
            const parts = dateStr.split('-');
            if (parts.length !== 2) return dateStr;
            const months = { 'Jan': 'January', 'Feb': 'February', 'Mar': 'March', 'Apr': 'April', 'May': 'May', 'Jun': 'June', 'Jul': 'July', 'Aug': 'August', 'Sep': 'September', 'Oct': 'October', 'Nov': 'November', 'Dec': 'December' };
            const month = months[parts[0]] || parts[0];
            let year = parseInt(parts[1], 10);
            if (year < 100) year += 2000;
            return `${month} ${year}`;
        }

        function getPriceChangeHtml(current, previous) {
            if (!current || !previous) return '';
            const change = ((current - previous) / previous) * 100;
            if (Math.abs(change) < 0.5) return '<span class="text-gray-500 text-xs">—</span>';
            const icon = change > 0 ? 'fa-arrow-up' : 'fa-arrow-down';
            const cls = change > 0 ? 'price-change-up' : 'price-change-down';
            return `<span class="${cls} text-xs font-bold"><i class="fa-solid ${icon} text-[10px]"></i> ${Math.abs(change).toFixed(1)}%</span>`;
        }

        async function loadTrends(append = false) {
            const loading = document.getElementById('loading');
            const loadMoreBtn = document.getElementById('load-more-btn');
            const grid = document.getElementById('trends-grid');

            if (!append) { currentOffset = 0; grid.innerHTML = ''; }
            loading.classList.remove('hidden');
            loadMoreBtn.classList.add('hidden');

            const brand = document.getElementById('brand-filter').value;
            const params = new URLSearchParams();
            if (brand) params.set('brand', brand);
            params.set('limit', LIMIT);
            params.set('offset', currentOffset);

            try {
                const res = await fetch(`/api/trends/cars?${params.toString()}`);
                const data = await res.json();

                document.getElementById('results-count').textContent = `${data.totalCount.toLocaleString()} models tracked`;

                if (!append && data.brands) {
                    const brandSelect = document.getElementById('brand-filter');
                    const currentVal = brandSelect.value;
                    brandSelect.innerHTML = '<option value="">All Brands</option>';
                    data.brands.forEach(b => {
                        const opt = document.createElement('option');
                        opt.value = b; opt.textContent = b;
                        brandSelect.appendChild(opt);
                    });
                    brandSelect.value = currentVal;
                }

                if (data.cars.length === 0 && !append) {
                    grid.innerHTML = `
                        <div class="col-span-full py-20 text-center">
                            <i class="fa-solid fa-chart-line text-5xl text-gray-700 mb-4"></i>
                            <h3 class="text-xl font-bold text-gray-400">No trends data found</h3>
                            <p class="text-gray-600 mt-2">Try adjusting your search or filters.</p>
                        </div>`;
                    loading.classList.add('hidden');
                    return;
                }

                data.cars.forEach(car => {
                    const card = document.createElement('a');
                    card.href = `/trends/${encodeURIComponent(car.brand)}/${encodeURIComponent(car.model)}`;
                    card.className = 'trend-card block';
                    
                    card.innerHTML = `
                        <div class="flex items-start justify-between mb-3">
                            <div class="flex-1 min-w-0">
                                <h3 class="text-lg font-bold text-gray-100 truncate flex items-center gap-2">
                                    ${car.brand} <span class="font-normal text-gray-400">${car.model}</span>
                                    ${car.production_years && car.production_years !== 'All' ? `<span class="text-xs font-bold uppercase tracking-wider text-blue-400 border border-blue-500/20 bg-blue-500/10 px-2 py-0.5 rounded-md flex-shrink-0">${car.production_years}</span>` : ''}
                                </h3>
                            </div>
                            <i class="fa-solid fa-arrow-right text-gray-600 group-hover:text-blue-400 text-sm mt-1 ml-2 flex-shrink-0"></i>
                        </div>
                        <div class="space-y-2.5 mt-4">
                            <div class="flex justify-between items-center">
                                <span class="text-xs text-gray-500 uppercase tracking-wider font-bold">Average</span>
                                <span class="text-blue-400 font-bold text-sm">${formatEGP(car.average_price)}</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-xs text-gray-500 uppercase tracking-wider font-bold">Min</span>
                                <span class="text-green-400 font-semibold text-sm">${formatEGP(car.min_price)}</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-xs text-gray-500 uppercase tracking-wider font-bold">Max</span>
                                <span class="text-orange-400 font-semibold text-sm">${formatEGP(car.max_price)}</span>
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-t border-white/5 flex items-center justify-between">
                            <span class="text-xs text-gray-600">Latest: ${formatMonthYear(car.latest_date) || '—'}</span>
                            <span class="text-xs text-blue-400 font-semibold">View Chart →</span>
                        </div>
                    `;
                    grid.appendChild(card);
                });

                if (currentOffset + LIMIT < data.totalCount) {
                    loadMoreBtn.classList.remove('hidden');
                }
            } catch(e) {
                console.error('Error loading trends:', e);
                grid.innerHTML = '<p class="text-red-400 col-span-full text-center py-10">Error loading data. Please try again.</p>';
            } finally {
                loading.classList.add('hidden');
            }
        }

        document.getElementById('brand-filter').addEventListener('change', () => loadTrends(false));

        document.getElementById('load-more-btn').addEventListener('click', () => {
            currentOffset += LIMIT;
            loadTrends(true);
        });

        loadTrends();
    </script>
</body>
</html>