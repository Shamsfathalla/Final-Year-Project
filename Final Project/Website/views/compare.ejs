<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <%- include('partials/head', { title: 'Compare Vehicles' }) %>
    <script type="module">
        import { initializeApp } from "firebase/app";
        import { getAuth, onAuthStateChanged } from "firebase/auth";
        import { firebaseConfig } from "/firebase-config.js";
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        onAuthStateChanged(auth, (user) => {
            window.firebaseUser = user;
            const saveBtn = document.getElementById('btn-save-comparison');
            if (saveBtn) saveBtn.style.display = user ? 'inline-flex' : 'none';
        });
    </script>
</head>
<body class="bg-dark-900 text-gray-100 h-screen overflow-hidden flex flex-col md:flex-row font-outfit">
    <%- include('partials/sidebar', { activePage: 'compare' }) %>

    <main class="flex-1 overflow-y-auto w-full h-full relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6" id="compare-content">
        <div class="mb-6 flex items-center justify-between">
            <h1 class="text-3xl font-black text-gray-100 tracking-tight">Compare Vehicles</h1>
            <button id="btn-save-comparison" style="display: none;" class="text-emerald-400 hover:text-emerald-300 font-bold px-4 py-2 bg-emerald-500/10 rounded-lg transition-colors hidden border border-emerald-500/20">
                <i class="fa-solid fa-bookmark mr-1"></i> Save Comparison
            </button>
            <button id="btn-clear-compare" class="text-red-400 hover:text-red-300 font-bold px-4 py-2 bg-red-500/10 rounded-lg transition-colors hidden border border-red-500/20">
                Clear All
            </button>
        </div>

        <div id="loading" class="flex justify-center py-20">
            <i class="fa-solid fa-spinner fa-spin text-4xl text-blue-500"></i>
        </div>
        
        <div id="error-msg" class="hidden text-center py-20 text-red-400 font-bold text-xl"></div>
        
        <div id="empty-state" class="hidden">
            <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
                <i class="fa-solid fa-code-compare text-6xl text-gray-700 mb-6 block"></i>
                <h2 class="text-3xl font-bold text-gray-400 mb-3">No cars selected for comparison.</h2>
                <p class="text-lg text-gray-600">Go back and select up to 3 cars to compare them side by side.</p>
            </div>
        </div>

        <div id="compare-table-container" class="hidden overflow-x-auto bg-dark-700 rounded-2xl shadow-lg border border-white/5 p-4">
            <!-- Table injected here -->
        </div>

        </div>
    </main>

    <script src="/compare-logic.js"></script>
    <script>
        const DEFAULT_IMG = 'https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&q=80&w=800';
        const clearBtn = document.getElementById('btn-clear-compare');
        const saveCompBtn = document.getElementById('btn-save-comparison');
        let currentCarsData = [];

        function formatPrice(price) {
            if (!price) return 'Contact for Price';
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'EGP',
                maximumFractionDigits: 0
            }).format(price);
        }

        async function loadCompareData() {
            const loading = document.getElementById('loading');
            const emptyState = document.getElementById('empty-state');
            const errorMsg = document.getElementById('error-msg');
            const container = document.getElementById('compare-table-container');

            loading.classList.remove('hidden');
            emptyState.classList.add('hidden');
            errorMsg.classList.add('hidden');
            container.classList.add('hidden');
            clearBtn.classList.add('hidden');

            const currentList = getCompareList();
            if (currentList.length === 0) {
                loading.classList.add('hidden');
                emptyState.classList.remove('hidden');
                return;
            }

            try {
                const fetchPromises = currentList.map(c => fetch(`/api/cars/${c.id}`).then(r => r.json()));
                const carsData = await Promise.all(fetchPromises);
                
                currentCarsData = carsData;
                loading.classList.add('hidden');
                container.classList.remove('hidden');
                clearBtn.classList.remove('hidden');
                if (window.firebaseUser) saveCompBtn.classList.remove('hidden');
                
                renderCompareTable(carsData);
            } catch(err) {
                console.error(err);
                loading.classList.add('hidden');
                errorMsg.classList.remove('hidden');
                errorMsg.innerText = 'Failed to load comparison data.';
            }
        }

        function renderCompareTable(cars) {
            const container = document.getElementById('compare-table-container');
            
            const features = [
                { key: 'price', label: 'Price', format: val => formatPrice(val) },
                { key: 'year', label: 'Year' },
                { key: 'mileage', label: 'Mileage', format: val => val ? Number(val).toLocaleString() + ' km' : '0 km' },
                { key: 'condition', label: 'Condition', format: (val, car) => {
                    let rawCond = car.car_condition || car['car condition'] || '';
                    let isNew = rawCond.toLowerCase() === 'new' || rawCond.toLowerCase() === 'brand new';
                    return isNew ? 'New' : (car.condition && String(car.condition).trim() !== '-' && String(car.condition).trim() !== '' ? car.condition : (rawCond || 'Used'));
                } },
                { key: 'brand_tier', label: 'Brand Tier' },
                { key: 'color', label: 'Color' },
                { key: 'seats', label: 'Seats' },
                { key: 'engine', label: 'Engine', format: (val, car) => (car.engine || 'N/A') + (car.cylinder_count ? ` (${car.cylinder_count})` : '') },
                { key: 'engine_capacity', label: 'Capacity', format: val => val ? val + 'L' : 'N/A' },
                { key: 'turbo_count', label: 'Turbos' },
                { key: 'horsepower', label: 'Horsepower', format: val => val ? val + ' HP' : 'N/A' },
                { key: 'torque', label: 'Torque', format: val => val ? val + ' Nm' : 'N/A' },
                { key: 'transmission', label: 'Transmission', format: val => val ? `<span class="capitalize">${val}</span>` : 'N/A'},
                { key: 'number_of_gears', label: 'Gears' },
                { key: 'drivetrain', label: 'Drivetrain' },
                { key: 'fuel_type', label: 'Fuel Type', format: val => val ? `<span class="capitalize">${val}</span>` : 'N/A' },
                { key: 'fuel_tank_capacity', label: 'Fuel Tank', format: val => val ? val + 'L' : 'N/A' },
                { key: 'fuel_consumption', label: 'Fuel Cons.', format: val => val ? val + ' L/100km' : 'N/A' },
                { key: 'electric_fuel_consumption', label: 'EV Cons.', format: val => val ? val + ' kWh/100km' : 'N/A' },
                { key: 'max_electric_driving_range', label: 'EV Range', format: val => val ? val + ' km' : 'N/A' },
                { key: 'body_type', label: 'Body Type', format: val => val ? `<span class="capitalize">${val}</span>` : 'N/A' },
                { key: 'acceleration', label: '0-100 km/h', format: val => val ? val + 's' : 'N/A' },
                { key: 'max_speed', label: 'Max Speed', format: val => val ? val + ' km/h' : 'N/A' },
                { key: 'length', label: 'Length', format: val => val ? val + ' mm' : 'N/A' },
                { key: 'width', label: 'Width', format: val => val ? val + ' mm' : 'N/A' },
                { key: 'height', label: 'Height', format: val => val ? val + ' mm' : 'N/A' },
                { key: 'wheelbase', label: 'Wheelbase', format: val => val ? val + ' mm' : 'N/A' },
                { key: 'model_average_price', label: 'Avg Price', format: val => val ? formatPrice(val) : 'N/A' },
                { key: 'model_min_price', label: 'Min Price', format: val => val ? formatPrice(val) : 'N/A' },
                { key: 'model_max_price', label: 'Max Price', format: val => val ? formatPrice(val) : 'N/A' }
            ];

            let html = '<table class="w-full text-left border-collapse min-w-[800px]">';
            
            html += '<thead><tr><th class="p-6 border-b border-white/5 w-1/4"></th>';
            cars.forEach(car => {
                const images = parseImagesLogic(car.image_paths);
                const coverImg = images.length > 0 ? images[0] : DEFAULT_IMG;
                html += `
                    <th class="p-6 border-b border-white/5 w-[25%] align-top">
                        <div class="relative group">
                            <img src="${coverImg}" class="w-full h-40 object-cover rounded-xl shadow-md mb-4 group-hover:shadow-lg transition-shadow" onerror="this.src='${DEFAULT_IMG}'">
                            <button onclick="removeCompareItem('${car.car_id}')" class="absolute -top-3 -right-3 bg-red-500 text-white rounded-full w-8 h-8 flex items-center justify-center shadow-md hover:bg-red-600 transition-colors">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                        <a href="/car/${car.car_id}" class="text-xl font-bold text-gray-100 block hover:text-blue-400 transition-colors">${car.brand} ${car.model}</a>
                        <span class="text-sm text-gray-500 font-medium">${car.trim || ''}</span>
                    </th>
                `;
            });
            html += '</tr></thead><tbody class="divide-y divide-white/5">';
            
            features.forEach(feat => {
                html += `<tr class="hover:bg-white/[0.02] transition-colors"><td class="p-4 font-bold text-gray-500 text-sm uppercase tracking-wider">${feat.label}</td>`;
                cars.forEach(car => {
                    let val = car[feat.key];
                    if (feat.format) val = feat.format(val, car);
                    html += `<td class="p-4 font-semibold text-gray-200 text-lg">${val !== undefined && val !== null ? val : '<span class="text-gray-700">-</span>'}</td>`;
                });
                html += '</tr>';
            });
            
            html += '</tbody></table>';
            container.innerHTML = html;
        }

        window.removeCompareItem = function(id) {
            toggleCompare(null, id, '', '');
            loadCompareData();
        }

        clearBtn.addEventListener('click', () => {
            clearComparison();
            loadCompareData();
        });

        // Save Comparison
        saveCompBtn.addEventListener('click', async () => {
            if (!window.firebaseUser || currentCarsData.length < 2) return;
            saveCompBtn.disabled = true;
            saveCompBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i> Saving...';
            try {
                const token = await window.firebaseUser.getIdToken();
                const carIds = currentCarsData.map(c => String(c.car_id));
                const comparisonData = currentCarsData.map(c => ({
                    car_id: c.car_id, brand: c.brand, model: c.model, trim: c.trim,
                    year: c.year, price: c.price, mileage: c.mileage,
                    condition: c.condition, car_condition: c.car_condition,
                    transmission: c.transmission, fuel_type: c.fuel_type,
                    body_type: c.body_type, engine: c.engine, horsepower: c.horsepower,
                    image_paths: c.image_paths
                }));
                const res = await fetch('/api/comparisons', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({ carIds, comparisonData })
                });
                if (res.ok) {
                    saveCompBtn.innerHTML = '<i class="fa-solid fa-check mr-1"></i> Saved!';
                    saveCompBtn.classList.remove('bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
                    saveCompBtn.classList.add('bg-emerald-600', 'text-white', 'border-emerald-600');
                    setTimeout(() => {
                        saveCompBtn.innerHTML = '<i class="fa-solid fa-bookmark mr-1"></i> Save Comparison';
                        saveCompBtn.classList.add('bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
                        saveCompBtn.classList.remove('bg-emerald-600', 'text-white', 'border-emerald-600');
                        saveCompBtn.disabled = false;
                    }, 2000);
                } else {
                    console.error('Save comparison error');
                    saveCompBtn.innerHTML = '<i class="fa-solid fa-bookmark mr-1"></i> Save Comparison';
                    saveCompBtn.disabled = false;
                }
            } catch(e) {
                console.error('Error saving comparison:', e);
                saveCompBtn.innerHTML = '<i class="fa-solid fa-bookmark mr-1"></i> Save Comparison';
                saveCompBtn.disabled = false;
            }
        });

        window.addEventListener('storage', (e) => {
            if (e.key === 'compareList') {
                window.compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
                loadCompareData();
            }
        });

        window.addEventListener('3arabeetak:compare-updated', () => {
            window.compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
            loadCompareData();
        });

        document.addEventListener('DOMContentLoaded', loadCompareData);
    </script>
    <%- include('partials/footer') %>
