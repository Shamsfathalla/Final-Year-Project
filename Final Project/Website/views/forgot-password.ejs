<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <%- include('partials/head', { title: 'Forgot Password' }) %>
    <style>
        .auth-page {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100%;
            padding: 40px 16px;
        }
        .auth-wrapper {
            width: 100%;
            max-width: 420px;
        }
        .auth-header {
            text-align: center;
            margin-bottom: 32px;
        }
        .auth-header .logo {
            font-size: 2.2rem;
            font-weight: 900;
            color: #3b82f6;
            letter-spacing: -0.04em;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 12px;
        }
        .auth-header p {
            color: #9ca3af;
            font-size: 0.95rem;
            margin: 0;
            line-height: 1.5;
        }
        .auth-card {
            background: #1a1a25;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 36px 32px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            animation: authSlideIn 0.4s ease-out;
        }
        
        /* Form fields */
        .auth-field { margin-bottom: 24px; }
        .auth-field label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #d1d5db;
            margin-bottom: 8px;
        }
        .auth-field .input-wrap {
            position: relative;
        }
        .auth-field .input-wrap > i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
            font-size: 0.9rem;
            pointer-events: none;
            transition: color 0.2s;
        }
        .auth-field input {
            width: 100%;
            height: 48px;
            padding: 0 16px 0 44px !important;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            background: #12121a !important;
            color: #f0f0f5 !important;
            font: inherit;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .auth-field input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }
        .auth-field input:focus + i { color: #3b82f6; }
        .auth-field input::placeholder { color: #6b7280; }

        /* Submit button */
        .auth-submit {
            width: 100%;
            height: 48px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: #fff;
            font: inherit;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .auth-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(59,130,246,0.4);
        }
        .auth-submit:active { transform: translateY(0); }

        /* Footer */
        .auth-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 0.85rem;
            color: #9ca3af;
        }
        .auth-footer a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: color 0.2s;
        }
        .auth-footer a:hover { color: #60a5fa; }

        /* Toast notification */
        .auth-toast {
            position: fixed;
            top: 24px;
            right: 24px;
            padding: 14px 22px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 600;
            z-index: 100;
            transform: translateX(120%);
            transition: transform 0.35s ease;
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }
        .auth-toast.show { transform: translateX(0); }
        .auth-toast.success { background: #065f46; color: #a7f3d0; border: 1px solid rgba(16,185,129,0.3); }
        .auth-toast.error { background: #7f1d1d; color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }

        /* Animations */
        @keyframes authSlideIn {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 480px) {
            .auth-card { padding: 28px 20px; }
            .auth-page { padding: 20px 12px; }
        }
    </style>
</head>
<body class="bg-dark-900 text-gray-100 h-screen overflow-hidden flex flex-col md:flex-row font-outfit">
    <%- include('partials/sidebar', { activePage: 'profile' }) %>

    <main class="flex-1 overflow-y-auto w-full h-full relative bg-dark-900">
        <div class="auth-page">
            <div class="auth-wrapper">
                <div class="auth-header">
                    <a href="/" class="logo">3arabeetak.</a>
                    <p>Enter your email address and we'll send you a link to reset your password.</p>
                </div>

                <div class="auth-card">
                    <form id="forgotPasswordForm" onsubmit="handleReset(event)">
                        <div class="auth-field">
                            <label for="reset-email">Email Address</label>
                            <div class="input-wrap">
                                <input type="email" id="reset-email" placeholder="you@example.com" required autocomplete="email">
                                <i class="fa-solid fa-envelope"></i>
                            </div>
                        </div>
                        <button type="submit" class="auth-submit">
                            <i class="fa-solid fa-paper-plane"></i> Send Reset Link
                        </button>
                    </form>

                    <div class="auth-footer">
                        <a href="/auth"><i class="fa-solid fa-arrow-left"></i> Back to Sign In</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-toast" id="authToast"></div>
    </main>

<script>
    function showToast(msg, type = 'success') {
        const toast = document.getElementById('authToast');
        toast.textContent = msg;
        toast.className = 'auth-toast ' + type;
        setTimeout(() => toast.classList.add('show'), 10);
        setTimeout(() => {
            toast.classList.remove('show');
        }, 3000);
    }

    function handleReset(e) {
        e.preventDefault();
        const email = document.getElementById('reset-email').value;
        if (email) {
            showToast('Password reset link sent! Check your email.', 'success');
            document.getElementById('forgotPasswordForm').reset();
        }
    }
</script>

<%- include('partials/footer') %>
