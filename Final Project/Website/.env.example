# Database Configuration
# Use Neon or PostgreSQL
# DATABASE_URL=postgresql://<username>:<password>@<neon_host>/<database>?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://<local_user>:<local_password>@<local_host>:5432/<database_name>

# Gemini Configuration
#GEMINI_API_KEY=your_gemini_api_key_here
#GEMINI_MODEL=gemini-3-flash-preview

# Model Configuration
LLM_MODEL=gemma3:4b

# Chatbot Service
CHATBOT_HOST=127.0.0.1
CHATBOT_PORT=5000
CHATBOT_DEBUG=true

# Node Service
NODE_PORT=3000
CHATBOT_API_URL=http://127.0.0.1:5000/chat

# Multimodal Service
MULTIMODAL_HOST=0.0.0.0
MULTIMODAL_PORT=5001
MULTIMODAL_DEBUG=true
MULTIMODAL_SECRET_KEY=your_multimodal_secret_key_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
